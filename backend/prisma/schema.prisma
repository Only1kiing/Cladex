generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents       Agent[]
  trades       Trade[]
  exchanges    Exchange[]
  activityLogs    ActivityLog[]
  paymentReceipts PaymentReceipt[]
  foundingPoints  Int          @default(10000)
  gasBalance      Float        @default(0)
  referredBy    String?
  referralCode  String?   @unique
  emailVerified    Boolean  @default(false)
  verificationCode String?
  verificationExp  DateTime?
}

enum Personality {
  NOVA
  SAGE
  APEX
  ECHO
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AgentStatus {
  RUNNING
  PAUSED
  STOPPED
}

model Agent {
  id          String      @id @default(cuid())
  userId      String
  name        String
  personality Personality
  strategy    Json
  riskLevel   RiskLevel
  assets      String[]
  status      AgentStatus @default(STOPPED)
  profit      Float       @default(0)
  totalTrades Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Subscription fields (for marketplace agents)
  sourceAgentId      String?
  subscriptionPrice  Float?
  subscriptionStatus String?   // "active" | "paused_no_gas" | "cancelled"
  nextBillingDate    DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades       Trade[]
  activityLogs ActivityLog[]
  signals      Signal[]

  @@index([userId])
}

enum TradeSide {
  BUY
  SELL
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

model Trade {
  id         String      @id @default(cuid())
  agentId    String?
  userId     String
  symbol     String
  side       TradeSide
  amount     Float
  price      Float
  profit     Float       @default(0)
  reason     String
  status     TradeStatus @default(OPEN)
  stopLoss   Float?
  takeProfit Float?
  createdAt  DateTime    @default(now())

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
}

model Exchange {
  id        String   @id @default(cuid())
  userId    String
  name      String
  apiKey    String
  apiSecret String
  connected Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ActivityType {
  TRADE
  INSIGHT
  ALERT
  NOVA
}

model ActivityLog {
  id        String       @id @default(cuid())
  userId    String
  agentId   String?
  type      ActivityType
  message   String
  data      Json?
  createdAt DateTime     @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([agentId])
}

model Signal {
  id          String   @id @default(cuid())
  agentId     String
  symbol      String
  side        String
  entryPrice  Float
  stopLoss    Float
  takeProfit  Float
  confidence  Int
  reason      String
  status      String   @default("active")
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
}

model PaymentReceipt {
  id          String   @id @default(cuid())
  userId      String
  plan        String
  amount      Float
  receiptData String   @db.Text
  fileName    String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
